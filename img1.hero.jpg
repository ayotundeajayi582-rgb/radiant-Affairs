  <style>
  /* Header Container */
.site-header {
  background: rgb(62, 62, 31); /* Soft, light sage green */
  border-bottom: 1px solid #e0d6c8;
  padding-bottom: 24px;
}

.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1200px;
  margin: 0 auto;
  padding: 32px 24px 0 24px;
}

.header-brand {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.site-logo {
  width: 64px;
  height: 64px;
  object-fit: contain;
  margin-bottom: 8px;
}

.logo-title {
  font-family: 'Montserrat', 'Arial', sans-serif;
  font-size: 2.2rem;
  letter-spacing: 6px;
  color: #b49b87;
  font-weight: 400;
  margin: 0;
  text-align: center;
}

.logo-sub {
  font-size: 1rem;
  letter-spacing: 3px;
  color: #b49b87;
  margin-top: 6px;
  text-align: center;
}

/* Center: Navigation */
.header-nav {
  flex: 2;
  display: flex;
  justify-content: center;
}

.header-nav ul {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24px 36px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.header-nav ul li a {
  text-decoration: none;
  color:  #92AA83;
  font-size: 1.08rem;
  letter-spacing: 3px;
  font-family: 'Montserrat', 'Arial', sans-serif;
  font-weight: 500;
  padding: 2px 0;
  transition: color 0.2s, border-bottom 0.2s;
  text-transform: uppercase;
  display: inline-block;
}

.header-nav ul li a.active,
.header-nav ul li a:hover {
  color: #b49b87;
  border-bottom: 2px solid #b49b87;
}

/* Actions: Contact & Socials */
.header-actions {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 24px;
  min-width: 0;
}

.contact-btn {
  background: none;
  border: 1px solid #b49b87;
  color: #b49b87;
  font-size: 1.08rem;
  letter-spacing: 2px;
  padding: 10px 28px;
  border-radius: 2px;
  font-family: 'Montserrat', 'Arial', sans-serif;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
  text-transform: uppercase;
  /* text-decoration: none; */
}
.contact-btn a {
  color: inherit;
  text-decoration: none;
}

.contact-btn:hover {
  background: #b49b87;
  color: #fff;
}

.socials a {
  color: #b49b87;
  font-size: 1.4rem;
  margin-right: 12px;
  transition: color 0.2s;
  text-decoration: none;
}

.socials a:last-child {
  margin-right: 0;
}

.socials a:hover {
  color: #3a2e27;
}

/* Menu Toggle (Mobile) */
.menu-toggle {
  display: none;
  font-size: 2rem;
  color: #b49b87;
  cursor: pointer;
  margin-left: 18px;
}

/* Responsive */
@media (max-width: 900px) {
  .header-bar {
    flex-direction: column;
    gap: 24px;
    padding-top: 10px;
    position: relative; /* Ensure relative positioning for absolute children */
  }
  .menu-toggle {
    display: inline-block;
    position: absolute;
    top: 18px;
    right: 24px;
    z-index: 100;
    margin-left: 0;
  }
  .header-nav {
    display: none;
    width: 100%;
    background: #f7f2eb;
    position: absolute;
    top: 70px;
    left: 0;
    z-index: 99;
    padding: 24px 0;
  }
  .header-nav.active {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .header-actions {
    margin-top: 16px;
    gap: 16px;
    justify-content: center;
  }
  .contact-btn {
    padding: 8px 18px;
    font-size: 1rem;
  }
  .site-logo {
    width: 48px;
    height: 48px;
  }
  .logo-title {
    font-size: 1.2rem;
  }
  .menu-toggle {
    display: inline-block;
  }
  .header-bar {
    position: relative;
  }
}

/* Dropdown styles */
.dropdown {
  position: relative;
}

.dropdown-toggle {
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  position: relative;
}

.dropdown-toggle i {
  transition: transform 0.3s ease;
}

.dropdown:hover .dropdown-toggle i {
  transform: rotate(180deg);
}

.dropdown-menu {
  display: none;
  position: absolute;
  top: calc(100% + 10px);
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ffffff 0%, #f9f6f2 100%);
  min-width: 220px;
  border-radius: 15px;
  padding: 20px 0;
  z-index: 100;
  font-family: 'Montserrat', 'Arial', sans-serif;
  box-shadow: 
    0 10px 40px rgba(180, 155, 135, 0.15),
    0 4px 15px rgba(180, 155, 135, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.9);
  border: 1px solid rgba(180, 155, 135, 0.1);
  opacity: 0;
  visibility: hidden;
  transform: translateX(-50%) translateY(-10px);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.dropdown:hover .dropdown-menu {
  display: block;
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
}

.dropdown-menu::before {
  content: '';
  position: absolute;
  top: -8px;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 8px solid transparent;
  border-right: 8px solid transparent;
  border-bottom: 8px solid #ffffff;
  filter: drop-shadow(0 -2px 4px rgba(180, 155, 135, 0.1));
}

.dropdown-menu li {
  list-style: none;
  margin: 0;
  padding: 0;
  position: relative;
}

.dropdown-menu li a {
  display: flex;
  align-items: center;
  padding: 12px 28px;
  color: #3a2e27;
  text-decoration: none;
  font-size: 0.95rem;
  font-weight: 500;
  transition: all 0.3s ease;
  text-transform: lowercase !important;
  letter-spacing: 1px;
  position: relative;
  overflow: hidden;
}

.dropdown-menu li a::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 3px;
  background: linear-gradient(135deg, #b49b87, #d4c4b0);
  transform: scaleY(0);
  transition: transform 0.3s ease;
  transform-origin: bottom;
}

.dropdown-menu li a::after {
  content: '';
  position: absolute;
  right: 20px;
  top: 50%;
  transform: translateY(-50%);
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #b49b87;
  opacity: 0;
  transition: all 0.3s ease;
}

.dropdown-menu li a:hover {
  background: linear-gradient(135deg, rgba(180, 155, 135, 0.08) 0%, rgba(180, 155, 135, 0.04) 100%);
  color: #b49b87;
  padding-left: 35px;
  letter-spacing: 1.5px;
}

.dropdown-menu li a:hover::before {
  transform: scaleY(1);
  transform-origin: top;
}

.dropdown-menu li a:hover::after {
  opacity: 1;
  right: 25px;
}

.dropdown-menu li:first-child a {
  border-radius: 15px 15px 0 0;
}

.dropdown-menu li:last-child a {
  border-radius: 0 0 15px 15px;
}

.dropdown-menu li:first-child:last-child a {
  border-radius: 15px;
}

/* Add subtle separator between items */
.dropdown-menu li:not(:last-child)::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 28px;
  right: 28px;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, rgba(180, 155, 135, 0.1) 50%, transparent 100%);
}

.dropdown .dropdown-menu {
  display: none;
}
</style>



