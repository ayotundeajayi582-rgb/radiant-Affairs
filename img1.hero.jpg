    /* General footer styling */
    .site-footer {
        background: #F7F2EB;
        /* Warm, muted off-white */
        color: #7a5b47;
        /* Soft brown for text */
        text-align: center;
        padding: 40px 20px 20px;
        font-family: "Georgia", serif;
    }

    .footer-top {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-around;
        margin-bottom: 30px;
    }

    .footer-logo img {
        width: 100px;
        margin-bottom: 20px;
    }

    .footer-signup h2,
    .footer-info h2 {
        color: #b49b87;
        /* Muted gold for headings */
        font-size: 22px;
        margin-bottom: 10px;
        font-weight: normal;
        letter-spacing: 2px;
    }

    .footer-signup p,
    .footer-signup small,
    .footer-info ul li em {
        color: #8d7a6b;
        /* Muted taupe for details */
        max-width: 350px;
        margin: 0 auto 20px;
        line-height: 1.5;
        font-size: 15px;
    }

    .signup-form {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 8px;
    }

    .signup-form input[type="email"] {
        padding: 12px;
        width: 260px;
        max-width: 100%;
        border: none;
        font-size: 15px;
        margin-bottom: 15px;
    }

    .signup-form button {
        padding: 12px 30px;
        background: transparent;
        color: #b49b87;
        border: 2px solid #b49b87;
        cursor: pointer;
        transition: 0.3s ease;
    }

    .signup-form button:hover {
        background: #b49b87;
        color: #fff;
    }

    /* Info section */
    .footer-info ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-info ul li {
        margin-bottom: 8px;
    }

    .footer-info ul li a {
        color: #b49b87;
        text-decoration: underline;
    }

    .footer-info ul li em {
        font-style: italic;
        font-size: 14px;
    }

    /* Logos row */
    .footer-logos {
        margin: 30px 0;
    }

    .footer-logos img {
        height: 60px;
        margin: 0 10px;
    }

    /* Bottom */
    .footer-bottom {
        background-color: #e9e5dc;
        /* Soft sand for bottom bar */
        color: #7a5b47;
    }

    .footer-bottom a {
        color: #b49b87;
        text-decoration: underline;
    }

    .design-credit {
        margin-top: 8px;
        font-weight: bold;
        color: #b49b87;
    }

    /* Toast notification */
    .signup-toast {
        position: fixed;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--bright-lime-tint, #E7F59E);
        color: var(--main-text, #1A1F36);
        padding: 16px 32px;
        border-radius: 8px;
        box-shadow: 0 4px 24px rgba(176, 190, 169, 0.18);
        font-size: 1.08rem;
        font-weight: 600;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s;
        z-index: 9999;
    }

    .signup-toast.show {
        opacity: 1;
        pointer-events: auto;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .footer-top {
            flex-direction: column;
            text-align: center;
        }

        .signup-form {
            width: 100%;
        }

        .footer-logos img {
            height: 50px;
            margin: 5px;
        }
    }
</style>


