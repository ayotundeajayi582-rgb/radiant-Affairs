  <script>
    // Dropdown menu toggle for SERVICES
    const serviceDropdown = document.querySelector('.dropdown');
    const serviceToggle = document.querySelector('.dropdown-toggle');
    const serviceMenu = document.querySelector('.dropdown-menu');
    if (serviceToggle && serviceMenu) {
      serviceToggle.addEventListener('click', function(e) {
        e.preventDefault();
        serviceMenu.style.display = serviceMenu.style.display === 'block' ? 'none' : 'block';
      });
      // Hide dropdown when clicking outside
      document.addEventListener('click', function(e) {
        if (!serviceDropdown.contains(e.target)) {
          serviceMenu.style.display = 'none';
        }
      });
    }
    // Mobile menu toggle
    const toggle = document.querySelector(".menu-toggle");
    const nav = document.querySelector("nav");
    toggle.addEventListener("click", () => {
      nav.classList.toggle("active");
    });

    // Set active nav link based on current page filename
    const navLinks = document.querySelectorAll('.header-nav ul li a');
    // Get the current page's filename (e.g., 'eventplanner.html')
    const currentFile = window.location.pathname.split('/').pop().split('\\').pop();
    navLinks.forEach(link => {
      let href = link.getAttribute('href');
      // Ignore anchor links
      if (href.startsWith('#')) {
        link.classList.remove('active');
        return;
      }
      // Get the filename part of the href
      const hrefFile = href.split('/').pop().split('\\').pop();
      if (hrefFile === currentFile) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
  </script>

